# BeoSound 5c Secrets
# Copy to /etc/beosound5c/secrets.env and fill in your values.
# All non-secret config lives in /etc/beosound5c/config.json

# Home Assistant
# Create HA_TOKEN at: HA -> Profile -> Long-Lived Access Tokens -> Create Token
# HA_URL is optional; if empty, services use home_assistant.url from config.json.
HA_URL=""
HA_WEBHOOK_URL=""
HA_TOKEN=""
HASS_FALLBACK_ENTITY=""
HASS_VOLUME_PRIORITY='[]'

# MQTT credentials (only needed if transport.mode includes "mqtt")
MQTT_USER=""
MQTT_PASSWORD=""

# Music Assistant / MASS (optional)
# MASS_WS_URL example: ws://musicassistant.local:8095/ws
MASS_WS_URL=""
MASS_TOKEN=""
MASS_QUEUE_ID=""
MASS_PLAYER_ID=""

# MasterLink Gateway bridge (optional, used by volume.type="hass")
MLGW_HOST=""
MLGW_PORT="9000"
MLGW_USER=""
MLGW_PASSWORD=""
MLGW_ENTITY_TO_MLN='{}'

# Kodi / LibreELEC (optional)
KODI_HOST=""
KODI_PORT="8080"
KODI_USER=""
KODI_PASSWORD=""

# WiiM (optional)
WIIM_HOST=""
VOLUME_HOST=""

# Spotify Integration
# Tokens are stored in /etc/beosound5c/spotify_tokens.json (managed by setup_spotify.py).
# The env vars below are only needed for legacy setups without PKCE.
# New setup: run 'python3 ~/beosound5c/tools/spotify/setup_spotify.py'

# Spotify Canvas (optional) — looping video backgrounds for tracks
# Get this from: open.spotify.com → DevTools → Application → Cookies → sp_dc
# Lasts ~1 year. Without this, Canvas video features are disabled (artwork-only immersive).
SPOTIFY_SP_DC=""

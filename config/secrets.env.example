# BeoSound 5c Secrets
# Copy to /etc/beosound5c/secrets.env and fill in your values.
# All non-secret config lives in /etc/beosound5c/config.json

# Home Assistant
HA_URL=""
HA_WEBHOOK_URL=""
HA_TOKEN=""
HASS_FALLBACK_ENTITY=""
HASS_VOLUME_PRIORITY='[]'

# MQTT credentials (only needed if transport.mode includes "mqtt")
MQTT_USER=""
MQTT_PASSWORD=""

# Music Assistant
PLAYER_IP=""
MASS_WS_URL=""
MASS_TOKEN=""
MASS_QUEUE_ID=""
MASS_PLAYER_ID=""

# MasterLink Gateway bridge
MLGW_HOST=""
MLGW_PORT="9000"
MLGW_USER=""
MLGW_PASSWORD=""
MLGW_ENTITY_TO_MLN='{}'

# Kodi / LibreELEC
KODI_HOST=""
KODI_PORT="8080"
KODI_USER=""
KODI_PASSWORD=""

# WiiM
WIIM_HOST=""
VOLUME_HOST=""
